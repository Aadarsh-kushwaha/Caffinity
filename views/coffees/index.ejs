<% layout("layouts/boilerplate") %>

<div class="hero-section"></div>

<style>
.hero-section {
    width: 100%;
    height: 100vh;
  background-image: url('https://res.cloudinary.com/dzcn4guhn/image/upload/v1782987791/home1_jifvul.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}

/* MOBILE FIX */
@media (max-width: 576px) {
    .hero-section {
        background-size: contain;      /* ⭐ width fix */
        background-position: top;
        background-color: #000;        /* background fill */
        height: 100vh;
    }
}


/* VERY SMALL PHONES FIX */
@media (max-width: 480px) {
    .hero-section {
        background-position: top;
    }
}
</style>
